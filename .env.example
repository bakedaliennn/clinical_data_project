# SaludMX Analytics Pipeline — Environment Variables
# Copy this file to .env and adjust paths for your machine.
# .env is git-ignored — credentials and local paths are NEVER committed.

# ════════════════════════════════════════════════════════════
# FUENTES DE DATOS — SECRETARÍA DE SALUD (SSA / DGIS)
# ════════════════════════════════════════════════════════════

# Carpeta local donde se colocan los archivos crudos de la SSA.
# Subcarpetas esperadas: saeh/, clues/, recursos_fisicos/, recursos_humanos/
SSA_DATA_DIR=C:\VSCode\clinical_data_project\data_raw

# Patrón glob para descubrir archivos SAEH (.csv, .xls, .xlsx)
XLS_GLOB=*.xls*

# ════════════════════════════════════════════════════════════
# POSTGRESQL — DATA WAREHOUSE (Star Schema)
# ════════════════════════════════════════════════════════════

# URL de conexión para SQLAlchemy / psycopg / Alembic.
# El host `localhost` funciona cuando el contenedor expone el puerto al host.
DATABASE_URL=postgresql+psycopg://saludmx_user:saludmx_pass@localhost:5432/saludmx_dw

# Variables consumidas por platform/orchestration/docker-compose.yml.
# DEBEN coincidir con las credenciales del DATABASE_URL arriba.
POSTGRES_USER=saludmx_user
POSTGRES_PASSWORD=saludmx_pass
POSTGRES_DB=saludmx_dw
POSTGRES_PORT=5432

# ════════════════════════════════════════════════════════════
# DAGSTER OSS — Orquestación y Observabilidad
# ════════════════════════════════════════════════════════════

# Puerto local para la UI de Dagster.
DAGSTER_WEBSERVER_PORT=3000

# Base separada dentro del mismo Postgres para metadata interna de Dagster.
DAGSTER_POSTGRES_DB=saludmx_dagster

# ════════════════════════════════════════════════════════════
# PGADMIN 4 — Administración Visual de Postgres
# ════════════════════════════════════════════════════════════

PGADMIN_DEFAULT_EMAIL=admin@saludmx.org
PGADMIN_DEFAULT_PASSWORD=adminpass
PGADMIN_PORT=5050

# ════════════════════════════════════════════════════════════
# PATHS INTERNOS DEL PIPELINE
# ════════════════════════════════════════════════════════════

# Carpeta raíz de logs del pipeline (un .log por corrida).
PIPELINE_LOGS_DIR=C:\VSCode\clinical_data_project\logs
